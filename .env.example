# Neon or Supabase Postgres connection string (server-side only — set in Vercel)
# Neon: Dashboard → Connection string → pooled
# Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret for API auth (set in Vercel for production)
JWT_SECRET=change-me-in-production

# Optional: Supabase Storage for asset images (otherwise images stored inline in DB)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
