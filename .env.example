# Neon or Supabase Postgres connection string (server-side only — set in Vercel)
# Neon: Dashboard → Connection string → pooled
# Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret for API auth (set in Vercel for production)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# ── Security (set these in production) ──────────────────────────────────────────

# Restrict API CORS to your production frontend origin.
# Leave unset only in local development (defaults to *).
ALLOWED_ORIGIN=https://your-app.vercel.app

# Shared secret required in X-Agent-Token header for agent registration & telemetry.
# When unset, agent endpoints are open (dev only). Generate with: openssl rand -base64 32
AGENT_SECRET=change-me-in-production

# ── Optional ─────────────────────────────────────────────────────────────────────

# Neon branch auto-provisioning (for dedicated DB per tenant).
# When set, creating an org with infrastructure_strategy=dedicated automatically
# creates a new Neon branch and runs the tenant schema on it.
# Get these from: Neon Console → Project → Settings → API Keys
# NEON_API_KEY=your-neon-personal-access-token
# NEON_PROJECT_ID=your-neon-project-id

# Optional: Supabase Storage for asset images (otherwise images stored inline in DB)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
